{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "opencode/big-pickle",
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@alergeek-ventures/opencode@latest",
    "@slkiser/opencode-quota",
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
    },
  },
  "permission": {
    "websearch": "allow",
  },
}
